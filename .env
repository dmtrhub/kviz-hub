# Docker / SQL Server
SA_PASSWORD=YourStrong@Password123
DATABASE_NAME=KvizHubDb

# JWT values used by docker-compose to populate Jwt__* inside backend container
JWT_KEY=this-is-a-long-secret-key-that-must-be-at-least-32-characters-for-HS256
JWT_ISSUER=https://api.example.com
JWT_AUDIENCE=https://app.example.com

# Frontend runtime (browser uses host URLs)
VITE_API_BASE_URL=http://localhost:7033/api
VITE_AVATAR_URL=http://localhost:7033